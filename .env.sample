# Optional: Cloudflare Turnstile site key used by widgets such as Contact Us.
CLOUDFLARE_TURNSTILE_SITE_KEY=

# Optional: Google Maps API key used by Store Finder and Region Map widgets.
GOOGLE_MAPS_API_KEY=

# Optional: Google place identifier used by the Google Reviews widget.
GOOGLE_PLACE_ID=

# Root directory of the target Magento installation.
TARGET_ROOT=/var/www/docker_mageos/magento

# Magento store view code used when resolving contracts and assets.
STORE_CODE=default

# Public base URL of the target Magento instance.
TARGET_SITEURL=https://mageos-docker.magsite.co.uk

# Hosts allowed to communicate with local ReactEdge services.
ALLOWED_HOSTS=localhost,127.0.0.1,mageos-docker.magsite.co.uk

# Enable server-side rendering for compatible widgets.
SSR_ENABLED=1

# Port used by `mise run widget-serve`.
SSR_PORT=4000

# Public URL exposed by Caddy and used by Magento to reach the SSR service.
SSR_BASE_URL=https://widgets-ssr.co.uk

# Development only. Never enable in production.
ALLOW_SELF_SIGNED_SSL=false